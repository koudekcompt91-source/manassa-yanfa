generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
  TEACHER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum CourseAccessType {
  FREE
  PAID
}

enum CourseStatus {
  DRAFT
  PUBLISHED
}

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum NotificationType {
  GENERAL
  LIVE_SESSION
  NEW_LESSON
  COURSE_ANNOUNCEMENT
  PAYMENT
}

enum ChatStatus {
  OPEN
  CLOSED
}

enum AssessmentType {
  QUIZ
  ASSIGNMENT
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  WRITTEN
}

enum SubmissionStatus {
  SUBMITTED
  PENDING_CORRECTION
  CORRECTED
}

enum LessonProgressStatus {
  STARTED
  COMPLETED
}

enum CertificateStatus {
  ACTIVE
  REVOKED
}

enum AnnouncementType {
  INFO
  SUCCESS
  WARNING
  URGENT
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  fullName       String
  role           Role          @default(STUDENT)
  /** Arabic label: الثالثة متوسط | الرابعة متوسط | الأولى ثانوي | الثانية ثانوي — students only */
  academicLevel  String?
  /** School year code: 3AM | 4AM | 1AS | 2AS — default unknown for legacy users */
  level            String        @default("unknown")
  phone            String?
  walletBalance  Int           @default(0)
  status         UserStatus    @default(ACTIVE)
  createdAt      DateTime      @default(now())

  rechargeRequests   RechargeRequest[]
  walletTransactions WalletTransaction[]
  enrollments        Enrollment[]
  notifications      Notification[]
  sentChatMessages   ChatMessage[]       @relation("ChatMessageSender")
  chatConversations  ChatConversation[]  @relation("ChatConversationStudent")
  assessmentSubmissions AssessmentSubmission[]
  lessonProgresses   LessonProgress[]
  certificates       Certificate[]
}

model RechargeRequest {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethod  String
  firstName      String
  lastName       String
  wilaya         String
  baladiya       String
  phone          String
  amount         Int
  receiptImage   String
  note           String    @default("")
  status         String    @default("pending")
  rejectionNote  String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
}

model WalletTransaction {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  amount            Int
  labelAr           String
  balanceAfter      Int
  rechargeRequestId String?
  packageId         String?
  note              String?
  createdAt         DateTime @default(now())
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId  String
  source     String
  paidMad    Int?
  enrolledAt DateTime @default(now())

  @@unique([userId, packageId])
}

model LearningPath {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  isPublished Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, order])
}

model HomepageBanner {
  id         String   @id @default(cuid())
  title      String
  subtitle   String?
  imageUrl   String?
  buttonText String?
  buttonUrl  String?
  isPublished Boolean @default(true)
  order      Int      @default(0)
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isPublished, order])
  @@index([startsAt, endsAt])
}

model NewsItem {
  id          String   @id @default(cuid())
  title       String
  summary     String
  icon        String?
  link        String?
  isPublished Boolean  @default(true)
  order       Int      @default(0)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, order])
  @@index([publishedAt])
}

model Announcement {
  id          String           @id @default(cuid())
  title       String
  message     String
  type        AnnouncementType @default(INFO)
  link        String?
  isPublished Boolean          @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([isPublished, createdAt])
  @@index([startsAt, endsAt])
}

model Course {
  id           String           @id @default(cuid())
  slug         String           @unique
  title        String
  description  String           @default("")
  accessType   CourseAccessType @default(FREE)
  price        Int              @default(0)
  status       CourseStatus     @default(DRAFT)
  categoryId   String?
  teacherId    String?
  thumbnailUrl String?
  isFeatured   Boolean          @default(false)
  order        Int              @default(0)
  academicLevel String?
  level         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  lessons      Lesson[]
  liveSessions LiveSession[]
  chatConversations ChatConversation[]
  assessments  Assessment[]
  lessonProgresses LessonProgress[]
  certificates      Certificate[]
}

model Lesson {
  id            String   @id @default(cuid())
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title         String
  youtubeUrl    String
  youtubeVideoId String
  description   String   @default("")
  order         Int
  isPublished   Boolean  @default(false)
  durationSec   Int?
  isFreePreview Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  progresses    LessonProgress[]

  @@index([courseId, order])
}

model LiveSession {
  id          String            @id @default(cuid())
  courseId    String
  course      Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String            @default("")
  zoomUrl     String
  startsAt    DateTime
  durationMin Int
  status      LiveSessionStatus @default(SCHEDULED)
  isPublished Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([courseId, startsAt])
  @@index([courseId, isPublished, startsAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType @default(GENERAL)
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

model ChatConversation {
  id            String       @id @default(cuid())
  courseId       String
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentId      String
  student        User         @relation("ChatConversationStudent", fields: [studentId], references: [id], onDelete: Cascade)
  status         ChatStatus   @default(OPEN)
  lastMessageAt  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  messages       ChatMessage[]

  @@unique([courseId, studentId])
  @@index([courseId, lastMessageAt])
  @@index([studentId, lastMessageAt])
}

model ChatMessage {
  id              String            @id @default(cuid())
  conversationId  String
  conversation    ChatConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User              @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body            String
  isRead          Boolean           @default(false)
  createdAt       DateTime          @default(now())

  @@index([conversationId, createdAt])
  @@index([conversationId, isRead])
}

model Assessment {
  id          String           @id @default(cuid())
  courseId    String
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String           @default("")
  type        AssessmentType
  isPublished Boolean          @default(false)
  dueDate     DateTime?
  allowRetake Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  questions   AssessmentQuestion[]
  submissions AssessmentSubmission[]

  @@index([courseId, isPublished, createdAt])
}

model AssessmentQuestion {
  id            String        @id @default(cuid())
  assessmentId  String
  assessment    Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionText  String
  type          QuestionType
  options       Json?
  correctAnswer Json?
  points        Int           @default(1)
  order         Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  answers       AssessmentAnswer[]

  @@index([assessmentId, order])
}

model AssessmentSubmission {
  id          String           @id @default(cuid())
  assessmentId String
  assessment  Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  studentId   String
  student     User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status      SubmissionStatus @default(SUBMITTED)
  score       Int              @default(0)
  maxScore    Int              @default(0)
  submittedAt DateTime?
  correctedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  answers     AssessmentAnswer[]

  @@index([assessmentId, studentId, createdAt])
}

model AssessmentAnswer {
  id             String               @id @default(cuid())
  submissionId   String
  submission     AssessmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId     String
  question       AssessmentQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer         Json?
  isCorrect      Boolean?
  pointsAwarded  Int                  @default(0)
  correctionNote String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([submissionId, questionId])
  @@index([questionId])
}

model LessonProgress {
  id          String               @id @default(cuid())
  studentId   String
  student     User                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status      LessonProgressStatus @default(STARTED)
  startedAt   DateTime             @default(now())
  completedAt DateTime?
  updatedAt   DateTime             @updatedAt

  @@unique([studentId, lessonId])
  @@index([studentId, courseId, status])
  @@index([courseId, status, updatedAt])
}

model Certificate {
  id              String            @id @default(cuid())
  certificateCode String            @unique
  studentId       String
  student         User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  issuedAt        DateTime          @default(now())
  completedAt     DateTime
  status          CertificateStatus @default(ACTIVE)
  revokedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([studentId, courseId])
  @@index([certificateCode, status])
  @@index([courseId, status, issuedAt])
}
