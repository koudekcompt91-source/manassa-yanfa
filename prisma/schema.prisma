generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  fullName       String
  role           Role          @default(STUDENT)
  /** Arabic label: الثالثة متوسط | الرابعة متوسط | الأولى ثانوي | الثانية ثانوي — students only */
  academicLevel  String?
  /** School year code: 3AM | 4AM | 1AS | 2AS — default unknown for legacy users */
  level            String        @default("unknown")
  phone            String?
  walletBalance  Int           @default(0)
  status         UserStatus    @default(ACTIVE)
  createdAt      DateTime      @default(now())

  rechargeRequests   RechargeRequest[]
  walletTransactions WalletTransaction[]
  enrollments        Enrollment[]
}

model RechargeRequest {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethod  String
  firstName      String
  lastName       String
  wilaya         String
  baladiya       String
  phone          String
  amount         Int
  receiptImage   String
  note           String    @default("")
  status         String    @default("pending")
  rejectionNote  String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
}

model WalletTransaction {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  amount            Int
  labelAr           String
  balanceAfter      Int
  rechargeRequestId String?
  packageId         String?
  note              String?
  createdAt         DateTime @default(now())
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId  String
  source     String
  paidMad    Int?
  enrolledAt DateTime @default(now())

  @@unique([userId, packageId])
}
